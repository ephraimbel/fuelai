6:["$","p",null,{"className":"text-stone text-sm leading-relaxed","children":"Fuel uses advanced AI to identify foods from photos and estimate nutritional content. We combine AI analysis with a database of 600+ foods calibrated against USDA data for accurate results."}]
7:["$","div","Is my food data private?",{"className":"mb-6","children":[["$","h3",null,{"className":"font-[family-name:var(--font-serif)] text-base text-ink mb-1.5","children":"Is my food data private?"}],["$","p",null,{"className":"text-stone text-sm leading-relaxed","children":"Yes. Food photos are processed by AI for analysis and are not stored on our servers afterward. Your food logs are stored securely and are only accessible to you."}]]}]
8:["$","div","How accurate is the calorie tracking?",{"className":"mb-6","children":[["$","h3",null,{"className":"font-[family-name:var(--font-serif)] text-base text-ink mb-1.5","children":"How accurate is the calorie tracking?"}],["$","p",null,{"className":"text-stone text-sm leading-relaxed","children":"Fuel provides AI-estimated nutritional values calibrated against USDA data. While no food tracking app can be 100% precise, our AI aims for the closest possible estimate and provides confidence levels for each analysis."}]]}]
9:["$","div","Can I use Fuel offline?",{"className":"mb-6","children":[["$","h3",null,{"className":"font-[family-name:var(--font-serif)] text-base text-ink mb-1.5","children":"Can I use Fuel offline?"}],["$","p",null,{"className":"text-stone text-sm leading-relaxed","children":"Fuel includes an on-device food database for basic lookups without an internet connection. However, AI-powered photo analysis and the chat nutritionist require an active internet connection."}]]}]
a:["$","div","How do I cancel my subscription?",{"className":"mb-6","children":[["$","h3",null,{"className":"font-[family-name:var(--font-serif)] text-base text-ink mb-1.5","children":"How do I cancel my subscription?"}],["$","p",null,{"className":"text-stone text-sm leading-relaxed","children":"You can manage or cancel your subscription at any time through your iPhone's Settings > Apple ID > Subscriptions. Cancellation takes effect at the end of the current billing period."}]]}]
b:["$","div","How do I delete my account?",{"className":"mb-6","children":[["$","h3",null,{"className":"font-[family-name:var(--font-serif)] text-base text-ink mb-1.5","children":"How do I delete my account?"}],["$","p",null,{"className":"text-stone text-sm leading-relaxed","children":"To delete your account and all associated data, email support@fuelapp.ai from the email address linked to your account. We will confirm deletion within 5 business days."}]]}]
