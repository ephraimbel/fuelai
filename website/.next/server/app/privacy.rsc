7:["$","h2",null,{"children":"3. AI Processing"}]
8:["$","p",null,{"children":"Fuel uses AI (powered by Anthropic's Claude) to analyze food photos and provide nutritional information. Food photos are sent to our AI service for analysis and are not retained after processing. We also maintain an on-device food database for faster, offline-capable lookups."}]
9:["$","h2",null,{"children":"4. Data Storage & Security"}]
a:["$","p",null,{"children":"Your data is stored securely using Supabase, which provides enterprise-grade security including encryption at rest and in transit. We implement appropriate technical and organizational measures to protect your personal information."}]
b:["$","h2",null,{"children":"5. Third-Party Services"}]
c:["$","ul",null,{"children":[["$","li",null,{"children":[["$","strong",null,{"children":"Supabase:"}]," Authentication and data storage"]}],["$","li",null,{"children":[["$","strong",null,{"children":"Anthropic (Claude AI):"}]," Food photo analysis and nutritional insights"]}],["$","li",null,{"children":[["$","strong",null,{"children":"Apple App Store:"}]," App distribution and in-app purchases"]}]]}]
d:["$","h2",null,{"children":"6. Data Retention"}]
e:["$","p",null,{"children":"We retain your account data for as long as your account is active. Food logs and nutritional data are retained to provide you with historical tracking and insights. You can request deletion of your account and all associated data at any time."}]
f:["$","h2",null,{"children":"7. Your Rights"}]
10:["$","ul",null,{"children":[["$","li",null,{"children":"Access the personal data we hold about you"}],["$","li",null,{"children":"Request correction of inaccurate data"}],["$","li",null,{"children":"Request deletion of your data"}],["$","li",null,{"children":"Export your data in a portable format"}],["$","li",null,{"children":"Opt out of non-essential data collection"}]]}]
11:["$","h2",null,{"children":"8. Children's Privacy"}]
12:["$","p",null,{"children":"The App is not intended for children under the age of 13. We do not knowingly collect personal information from children under 13."}]
13:["$","h2",null,{"children":"9. Changes to This Policy"}]
14:["$","p",null,{"children":"We may update this Privacy Policy from time to time. We will notify you of any changes by posting the new Privacy Policy on this page and updating the “Last updated” date."}]
15:["$","h2",null,{"children":"10. Contact Us"}]
16:["$","p",null,{"children":["If you have questions about this Privacy Policy, please contact us at"," ",["$","a",null,{"href":"mailto:support@fuelapp.ai","children":"support@fuelapp.ai"}],"."]}]
