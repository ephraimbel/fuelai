n, and unique device identifiers for app functionality and troubleshooting."]}],["$","h2",null,{"children":"2. How We Use Your Information"}],["$","ul",null,{"children":[["$","li",null,{"children":"To provide, maintain, and improve the App's functionality"}],["$","li",null,{"children":"To analyze your meals and provide AI-powered nutritional insights"}],["$","li",null,{"children":"To personalize your experience and provide relevant recommendations"}],["$","li",null,{"children":"To communicate with you about updates, support, and service-related notices"}],"$L6"]}],"$L7","$L8","$L9","$La","$Lb","$Lc","$Ld","$Le","$Lf","$L10","$L11","$L12","$L13","$L14","$L15","$L16"]}]]}]}],null,"$L17"]}],{},null,false]},null,false]},null,false],"$L18",false]],"m":"$undefined","G":["$19",[]],"s":false,"S":true}
